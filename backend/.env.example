# Server configuration
PORT=5000
NODE_ENV=production

# JWT secret key for admin authentication
JWT_SECRET=replace_this_with_a_secure_random_string_in_production

# CORS allowed origin (e.g. Firebase Hosting domain)
# Example: https://kalaakar-art.web.app or https://mybusiness.in
ALLOWED_ORIGIN=https://mybusiness.in

# Email service configuration (Optional - for real email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Kalaakar Art Studio <hello@kalaakar.com>"
